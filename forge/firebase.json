{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "firestore.rules",
      "firestore.indexes.json",
      ".firebaserc",
      "README.md",
      "**/.*"
    ],
    "cleanUrls": true,
    "headers": [
      {
        "source": "**/*.@(js|css|svg)",
        "headers": [{ "key": "Cache-Control", "value": "public, max-age=3600" }]
      }
    ]
  },
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "emulators": {
    "auth": { "port": 9099 },
    "firestore": { "port": 8081 },
    "hosting": { "port": 5000 },
    "ui": { "enabled": true }
  }
}
